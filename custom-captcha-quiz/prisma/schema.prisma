generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Quiz {
  id                  String     @id @default(cuid())
  title               String
  description         String?
  maxAttempts         Int        @default(3)
  sessionMax          Int        @default(10)
  questionsPerSession Int        @default(3)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  questions           Question[]
  sessions            Session[]
}

model Question {
  id        String   @id @default(cuid())
  quizId    String
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices   Choice[]
  answers   Answer[]
}

model Choice {
  id         String   @id @default(cuid())
  questionId String
  text       String
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  quizId    String
  token     String   @unique
  signature String
  ipAddress String?
  userAgent String?
  totalTime Int?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  choiceId   String?
  isCorrect  Boolean  @default(false)
  timeTaken  Int?
  attempt    Int      @default(1)
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
